model PanelVersion {
  id        String   @id @default(cuid())
  docName   String   // panel:{resourceSlug}:{recordId}
  snapshot  Bytes    // Y.encodeStateAsUpdate(doc)
  label     String?  // optional user-provided label
  userId    String?  // who saved this version
  createdAt DateTime @default(now())

  @@index([docName, createdAt])
}

model PanelGlobal {
  slug      String   @id
  data      String   @default("{}")  // JSON stored as string for SQLite compatibility
  updatedAt DateTime @updatedAt
}

model AiConversation {
  id            String          @id @default(cuid())
  userId        String?
  title         String          @default("New conversation")
  resourceSlug  String?
  recordId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  messages      AiChatMessage[]

  @@index([userId, updatedAt])
  @@index([resourceSlug, recordId, updatedAt])
}

model AiChatMessage {
  id              String          @id @default(cuid())
  conversationId  String
  conversation    AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String
  toolCalls       String?         // JSON string of ToolCall[]
  toolCallId      String?
  createdAt       DateTime        @default(now())

  @@index([conversationId, createdAt])
}
