{
  "name": "boostkit",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "artisan": "tsx packages/cli/src/index.ts",
    "test": "turbo run test",
    "docs:dev": "turbo run docs:dev --filter=@boostkit/docs",
    "docs:build": "turbo run docs:build --filter=@boostkit/docs",
    "docs:preview": "cd docs && pnpm preview",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "msgpackr-extract",
      "protobufjs",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
